{
  "name": "kiroductor",
  "version": "0.0.4",
  "description": "Electron ACP client for kiro-cli",
  "type": "module",
  "main": "out/main/index.mjs",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "start": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder --dir",
    "make": "electron-vite build && electron-builder",
    "make:mac": "electron-vite build && electron-builder --mac --publish never",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test:vrt": "playwright test",
    "test:vrt:update": "playwright test --update-snapshots"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.0",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@lobehub/icons": "^5.0.1",
    "@shikijs/rehype": "^4.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "lucide-animated": "^1.0.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-diff-view": "^3.3.2",
    "react-dom": "^19.2.4",
    "react-file-icon": "^1.6.0",
    "react-markdown": "^10.1.0",
    "refractor": "^3.6.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "unique-names-generator": "^4.7.1",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "lefthook"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-file-icon": "^1.0.4",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fix-path": "^5.0.0",
    "happy-dom": "^20.8.4",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
